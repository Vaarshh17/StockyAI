# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
# Get from: Telegram → @BotFather → /newbot

# ── Z.AI / GLM ────────────────────────────────────────────────────────────────
GLM_API_KEY=your_zhipu_api_key_here
# Get from: open.bigmodel.cn → API Keys
GLM_MODEL=glm-4v-plus
GLM_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_DB_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Get from: supabase.com → Your Project → Settings → Database → URI (use Transaction pooler)
# IMPORTANT: Add ?ssl=require at the end if connection fails

# ── Scheduler ─────────────────────────────────────────────────────────────────
MORNING_BRIEF_HOUR=3
MORNING_BRIEF_MIN=30
# For demo: set to current time + 2 min to trigger immediately

# ── Defaults ──────────────────────────────────────────────────────────────────
DEFAULT_CITY=Kuala Lumpur
DEFAULT_LANGUAGE=malay

# ── Dev mode ──────────────────────────────────────────────────────────────────
# Set DEMO_MODE=True to skip GLM API calls (uses mock responses)
DEMO_MODE=False
